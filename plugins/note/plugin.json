{
  "manifest_version": 1,
  "id": "note",
  "name": "Note",
  "version": "0.2.0",
  "kind": "widget",
  "description": "A free-text note that uses the active theme's colours. Writes whatever you want and auto-scales to the cell. For a real sticky-yellow look, override the cell's bg/accent via the per-cell colour overrides on the editor.",
  "icon": "ph-note",
  "supports": { "sizes": ["xs", "sm", "md", "lg"] },
  "cell_options": [
    {
      "name": "text",
      "type": "textarea",
      "label": "Note text",
      "default": "Write your note here.\nUse line breaks for paragraphs."
    },
    {
      "name": "title",
      "type": "string",
      "label": "Title (optional)",
      "default": ""
    },
    {
      "name": "align",
      "type": "select",
      "label": "Alignment",
      "default": "left",
      "choices": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "name": "weight",
      "type": "select",
      "label": "Weight",
      "default": "500",
      "choices": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ]
    }
  ],
  "render": { "dither": "none" }
}
