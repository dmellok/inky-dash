      },
      {
        "key": "WEATHER_ICON_SET",
        "label": "Icon set",
        "type": "select",
        "default": "phosphor",
        "choices": [
          {"value": "phosphor",  "label": "Phosphor (monochrome, theme color)"},
          {"value": "meteocons", "label": "Meteocons (full-color)"}
        ]
      }
    ]
  }
