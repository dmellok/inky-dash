{
  "manifest_version": 1,
  "id": "weather",
  "name": "Weather",
  "version": "0.1.0",
  "kind": "widget",
  "description": "Current temp + 3-day outlook from open-meteo. No API key needed.",
  "supports": { "sizes": ["xs", "sm", "md", "lg"] },
  "cell_options": [
    { "name": "latitude", "type": "number", "label": "Latitude", "default": -37.6494 },
    { "name": "longitude", "type": "number", "label": "Longitude", "default": 145.1004 },
    { "name": "label", "type": "string", "label": "Place label", "default": "South Morang" },
    {
      "name": "units",
      "type": "select",
      "label": "Units",
      "default": "metric",
      "choices": [
        { "value": "metric", "label": "Metric (°C)" },
        { "value": "imperial", "label": "Imperial (°F)" }
      ]
    }
  ],
  "render": { "dither": "none", "needs_network": true }
}
