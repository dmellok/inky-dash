{
  "manifest_version": 1,
  "id": "wikipotd",
  "name": "Wikimedia POTD",
  "version": "0.1.0",
  "kind": "widget",
  "description": "Wikimedia Commons Picture of the Day. Pulls from the public feed API; no auth needed.",
  "icon": "ph-camera",
  "supports": { "sizes": ["sm", "md", "lg"] },
  "cell_options": [
    {
      "name": "show_caption",
      "type": "boolean",
      "label": "Show caption overlay",
      "default": true
    },
    {
      "name": "scale",
      "type": "select",
      "label": "Scale",
      "default": "fit",
      "choices": [
        { "value": "fit", "label": "Fit (letterbox)" },
        { "value": "fill", "label": "Fill (crop to cover)" },
        { "value": "stretch", "label": "Stretch (distort to fill)" },
        { "value": "blurred", "label": "Fit with blurred background" }
      ]
    }
  ],
  "render": { "dither": "floyd-steinberg", "needs_network": true, "full_bleed": true }
}
