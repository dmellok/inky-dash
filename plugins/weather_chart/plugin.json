{
  "manifest_version": 1,
  "id": "weather_chart",
  "name": "Weather chart",
  "version": "0.1.0",
  "kind": "widget",
  "description": "Current temp + 24h hourly forecast as a sparkline-style line chart with min/max markers. open-meteo (no API key).",
  "icon": "ph-chart-line",
  "supports": { "sizes": ["md", "lg"] },
  "cell_options": [
    { "name": "latitude", "type": "number", "label": "Latitude", "default": 51.5074 },
    { "name": "longitude", "type": "number", "label": "Longitude", "default": -0.1278 },
    { "name": "label", "type": "string", "label": "Place label", "default": "London" },
    {
      "name": "units",
      "type": "select",
      "label": "Units",
      "default": "metric",
      "choices": [
        { "value": "metric", "label": "Metric (°C)" },
        { "value": "imperial", "label": "Imperial (°F)" }
      ]
    },
    {
      "name": "hours",
      "type": "select",
      "label": "Hours of forecast",
      "default": "24",
      "choices": [
        { "value": "12", "label": "12 hours" },
        { "value": "24", "label": "24 hours" },
        { "value": "48", "label": "48 hours" }
      ]
    }
  ],
  "render": { "dither": "none", "needs_network": true }
}
