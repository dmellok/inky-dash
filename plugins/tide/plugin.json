{
  "id": "tide",
  "label": "Tide chart",
  "icon": "ph-wave-triangle",
  "version": "1.0.0",
  "kinds": ["widget"],
  "cell_options": [
    {
      "name": "lat",
      "label": "Latitude",
      "type": "text",
      "default": "-37.8500"
    },
    {
      "name": "lng",
      "label": "Longitude",
      "type": "text",
      "default": "144.9600"
    },
    {
      "name": "place_label",
      "label": "Location label",
      "type": "text",
      "default": "Port Phillip Bay"
    },
    {
      "name": "show_header",
      "label": "Show widget header",
      "type": "bool",
      "default": true
    }
  ],
  "settings": {
    "title": "Tide chart",
    "fields": [
      {
        "key": "TIDE_CACHE_S",
        "label": "Cache (seconds)",
        "type": "int",
        "default": 1800
      }
    ]
  }
}
