      "label": "Icon (Phosphor name, e.g. ph-cake)",
      "type": "text",
      "default": "ph-hourglass"
    },
    {
      "name": "show_header",
      "label": "Show widget header",
      "type": "bool",
      "default": true
    }
  ]
}
