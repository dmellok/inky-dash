{
  "id": "crypto",
  "label": "Crypto prices",
  "icon": "ph-currency-btc",
  "version": "1.0.0",
  "kinds": ["widget"],
  "cell_options": [
    {
      "name": "ids",
      "label": "CoinGecko IDs (comma-separated)",
      "type": "text",
      "default": "bitcoin,ethereum,solana"
    },
    {
      "name": "vs",
      "label": "Quote currency (e.g. usd, eur, aud, btc, eth)",
      "type": "text",
      "default": "usd"
    },
    {
      "name": "sparkline",
      "label": "Show 7-day sparkline",
      "type": "bool",
      "default": true
    },
    {
      "name": "show_header",
      "label": "Show widget header",
      "type": "bool",
      "default": true
    }
  ],
  "settings": {
    "title": "Crypto prices",
    "fields": [
      {
        "key": "CRYPTO_CACHE_S",
        "label": "Cache (seconds)",
        "type": "int",
        "default": 300
      }
    ]
  }
}
