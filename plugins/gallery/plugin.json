{
  "manifest_version": 1,
  "id": "gallery",
  "name": "Gallery",
  "version": "0.2.0",
  "kind": "widget",
  "description": "Rotates through images in a folder. Manage folders + uploads at /plugins/gallery/.",
  "icon": "ph-images",
  "supports": { "sizes": ["md", "lg"] },
  "cell_options": [
    {
      "name": "folder",
      "type": "select",
      "label": "Folder",
      "default": "",
      "choices_from": "folders"
    },
    {
      "name": "orientation",
      "type": "select",
      "label": "Orientation",
      "default": "any",
      "choices": [
        { "value": "any", "label": "Any" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" },
        { "value": "square", "label": "Square" }
      ]
    },
    {
      "name": "mode",
      "type": "select",
      "label": "Selection",
      "default": "random",
      "choices": [
        { "value": "random", "label": "Random" },
        { "value": "sequential", "label": "Sequential (rotates each render)" }
      ]
    },
    {
      "name": "scale",
      "type": "select",
      "label": "Scale",
      "default": "fit",
      "choices": [
        { "value": "fit", "label": "Fit (letterbox)" },
        { "value": "fill", "label": "Fill (crop to cover)" },
        { "value": "stretch", "label": "Stretch (distort to fill)" },
        { "value": "center", "label": "Center (no scaling)" },
        { "value": "blurred", "label": "Fit with blurred background" }
      ]
    }
  ],
  "render": { "dither": "floyd-steinberg", "full_bleed": true }
}
