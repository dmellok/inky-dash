# Environment / secrets
.env
.env.local

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local user state — committed via .env.example + the bundled plugin
# manifests. Per-user dashboards, schedules, todos, gallery folder paths,
# render PNG cache, upload sandbox, push history.
data/
!data/.gitkeep

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs / temp
*.log
/tmp/inky_dev.log

# Stress-test artifacts — the harness in `tools/stress_test.py` generates
# these locally; never commit them (the report links into renders/stress/
# and 25 MB of PNGs has no business living in git).
STRESS_REPORT.md
renders/stress/

# Internal design docs (excluded by repo owner)
v3-brief.md
v3-plugins.md

# Blog post drafts + their screenshots
docs/blog.md
docs/blog-screenshots/
