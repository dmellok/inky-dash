{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inky-dash.local/schema/page.schema.json",
  "title": "Inky Dash page",
  "description": "A page is a panel-sized canvas of cells; each cell mounts one widget plugin. See docs/v4-brief.md §10.",
  "type": "object",
  "required": ["id", "name", "panel", "cells"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_][a-z0-9_-]*$",
      "description": "URL-safe identifier. Lowercase, may include digits, _, -. Leading underscore reserved for built-in pages (e.g. _demo)."
    },
    "name": { "type": "string", "minLength": 1 },
    "panel": { "$ref": "#/$defs/panel" },
    "theme": {
      "type": "string",
      "default": "default",
      "description": "Theme id resolved by themes_core."
    },
    "font": {
      "type": "string",
      "default": "default",
      "description": "Font id resolved by fonts_core."
    },
    "gap": {
      "type": "integer",
      "minimum": 0,
      "maximum": 200,
      "default": 0,
      "description": "Pixel gap inset around every cell. Half is applied per side, so adjacent cells get the full gap between them and the panel edges get half."
    },
    "corner_radius": {
      "type": "integer",
      "minimum": 0,
      "maximum": 200,
      "default": 0,
      "description": "Rounded corners on each cell, in pixels."
    },
    "bleed_color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "default": "#ffffff",
      "description": "Hex color that bleeds through the gap between cells and behind rounded corners."
    },
    "icon": {
      "type": "string",
      "pattern": "^ph-[a-z0-9-]+$",
      "description": "Phosphor icon class (optional)."
    },
    "cells": {
      "type": "array",
      "items": { "$ref": "#/$defs/cell" }
    }
  },
  "$defs": {
    "panel": {
      "type": "object",
      "required": ["w", "h"],
      "additionalProperties": false,
      "properties": {
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      }
    },
    "cell": {
      "type": "object",
      "required": ["id", "x", "y", "w", "h", "plugin"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 },
        "plugin": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "options": { "type": "object" },
        "theme": {
          "type": "string",
          "description": "Optional theme id override; falls back to the page's theme."
        },
        "font": {
          "type": "string",
          "description": "Optional font id override; falls back to the page's font."
        }
      }
    }
  }
}
